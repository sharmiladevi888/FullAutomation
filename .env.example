# --- Image generation (gpt-image-2 via derouter OpenAI-compatible proxy) ---
DEROUTER_API_KEY=
DEROUTER_BASE_URL=https://api-direct.derouter.network/openai/v1
IMAGE_MODEL=gpt-image-2
DEFAULT_SIZE=1536x1024
DEFAULT_QUALITY=high
# Set to "true" ONLY if you've verified your proxy accepts repeated `image[]`
# multipart fields on /images/edits. The derouter docs only document a single
# `image` field, so the default is the safer contact-sheet fallback.
MULTI_IMAGE_EDIT=false

# --- Image generation QUEUE / rate-limit handling --------------------------
# Bulk image generation is run through a controlled queue with exponential
# backoff + a global cooldown so we never trip the API's tokens-per-minute rate
# limit (the "Rate limit reached ... Limit 4000, Used 4000" errors). Defaults
# are safe; raise IMAGE_MAX_CONCURRENCY only if your plan's limits allow it.
# SPEED vs. rate-limits: with a tokens-per-minute cap you can't go fully fast
# without occasionally touching the limit — but retries make those hits silent.
# To go FASTER: raise IMAGE_MAX_CONCURRENCY (if your plan allows) and/or lower
# IMAGE_RATE_LIMIT_COOLDOWN_MS. To NEVER hit the limit: set concurrency=1 and a
# larger delay/cooldown. The cooldown is adaptive (escalates only while the limit
# stays saturated, resets after any success), so these defaults stay quick.
IMAGE_MAX_CONCURRENCY=2          # how many image requests may run at once
IMAGE_REQUEST_DELAY_MS=50        # minimum gap between starting two requests
IMAGE_MAX_RETRIES=6             # attempts per prompt before it's marked failed
IMAGE_BACKOFF_BASE_MS=1500       # base for exponential backoff on server errors
IMAGE_BACKOFF_MAX_MS=30000       # ceiling for a single backoff wait
IMAGE_RATE_LIMIT_COOLDOWN_MS=18000  # base whole-queue pause after a 429 (adaptive)

# --- Claude (script gen, vision-from-video, edit planning) via derouter ---
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.derouter.network/proxy
CLAUDE_MODEL=claude-sonnet-4-6

# --- 9Router (OPTIONAL local AI router / token-saver for Claude calls) ------
# Route Claude/text calls through a locally-running 9Router instance
# (https://github.com/decolua/9router) for 20-40% token savings + free/cheap
# fallback. Install: `npm i -g 9router`, then run `9router` (dashboard at
# http://localhost:20128). Connect a provider in its dashboard, copy the API
# key, and either set it here or paste it in Settings -> Provider: 9Router.
# Only affects Claude/text — image generation keeps using the image provider.
NINEROUTER_API_KEY=
NINEROUTER_BASE_URL=http://localhost:20128
NINEROUTER_MODEL=kr/claude-sonnet-4.5
# Optionally also route IMAGE generation through 9Router (image provider →
# 9Router in Settings). 9Router targets chat/code models, so images only work if
# the provider you connect exposes an OpenAI images endpoint — otherwise leave
# image generation on the derouter provider.
NINEROUTER_IMAGE_BASE_URL=http://localhost:20128/v1
NINEROUTER_IMAGE_MODEL=gpt-image-1

# --- ElevenLabs (voice-over: script text -> spoken audio) ------------------
# Get a key at https://elevenlabs.io (Profile -> API key). Can also be pasted
# in the in-app Settings panel. The Edit tab lists your account's voices.
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2
