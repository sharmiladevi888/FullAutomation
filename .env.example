# --- Image generation (gpt-image-2 via derouter OpenAI-compatible proxy) ---
DEROUTER_API_KEY=
DEROUTER_BASE_URL=https://api-direct.derouter.network/openai/v1
IMAGE_MODEL=gpt-image-2
DEFAULT_SIZE=1536x1024
DEFAULT_QUALITY=high
# Set to "true" ONLY if you've verified your proxy accepts repeated `image[]`
# multipart fields on /images/edits. The derouter docs only document a single
# `image` field, so the default is the safer contact-sheet fallback.
MULTI_IMAGE_EDIT=false

# --- Image generation QUEUE / rate-limit handling --------------------------
# Bulk image generation is run through a controlled queue with exponential
# backoff + a global cooldown so we never trip the API's tokens-per-minute rate
# limit (the "Rate limit reached ... Limit 4000, Used 4000" errors). Defaults
# are safe; raise IMAGE_MAX_CONCURRENCY only if your plan's limits allow it.
IMAGE_MAX_CONCURRENCY=1          # how many image requests may run at once
IMAGE_REQUEST_DELAY_MS=1500      # minimum gap between starting two requests
IMAGE_MAX_RETRIES=5             # attempts per prompt before it's marked failed
IMAGE_BACKOFF_BASE_MS=2000       # base for exponential backoff on server errors
IMAGE_BACKOFF_MAX_MS=60000       # ceiling for a single backoff wait
IMAGE_RATE_LIMIT_COOLDOWN_MS=65000  # whole-queue pause after a rate-limit/429

# --- Claude (script gen, vision-from-video, edit planning) via derouter ---
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.derouter.network/proxy
CLAUDE_MODEL=claude-sonnet-4-6

# --- ElevenLabs (voice-over: script text -> spoken audio) ------------------
# Get a key at https://elevenlabs.io (Profile -> API key). Can also be pasted
# in the in-app Settings panel. The Edit tab lists your account's voices.
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2
